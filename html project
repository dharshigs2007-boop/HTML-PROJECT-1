<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Complete Web App</title>
<link rel="stylesheet" href="style.css">
</head>
<body>

<!-- Navigation -->
<nav>
    <div class="logo">MyApp</div>

    <ul>
        <li><a href="#" onclick="showPage('landing')">Home</a></li>
        <li><a href="#" onclick="showPage('login')">Login</a></li>
        <li><a href="#" onclick="showPage('signup')">Signup</a></li>
        <li><a href="#" onclick="showPage('dashboard')">Dashboard</a></li>
        <li><a href="#" onclick="showPage('settings')">Settings</a></li>
    </ul>
</nav>

<!-- Landing Page -->
<section id="landing" class="page active">
    <div class="hero">
        <h1>Welcome to MyApp</h1>
        <p>All your work in one place.</p>
        <button onclick="showPage('signup')">
            Get Started
        </button>
    </div>
</section>

<!-- Login Page -->
<section id="login" class="page">
    <div class="form-box">
        <h2>Login</h2>

        <input type="email" placeholder="Email">
        <input type="password" placeholder="Password">

        <button>Login</button>

        <p>
            Don't have an account?
            <a href="#" onclick="showPage('signup')">
                Signup
            </a>
        </p>
    </div>
</section>

<!-- Signup Page -->
<section id="signup" class="page">
    <div class="form-box">
        <h2>Create Account</h2>

        <input type="text" placeholder="Full Name">
        <input type="email" placeholder="Email">
        <input type="password" placeholder="Password">

        <button>Create Account</button>

        <p>
            Already have an account?
            <a href="#" onclick="showPage('login')">
                Login
            </a>
        </p>
    </div>
</section>

<!-- Dashboard -->
<section id="dashboard" class="page">
    <div class="dashboard">

        <div class="card">
            <h3>Total Users</h3>
            <h1>150</h1>
        </div>

        <div class="card">
            <h3>Total Projects</h3>
            <h1>25</h1>
        </div>

        <div class="card">
            <h3>Revenue</h3>
            <h1>$12,500</h1>
        </div>

    </div>
</section>

<!-- Settings -->
<section id="settings" class="page">
    <div class="form-box">

        <h2>Settings</h2>

        <input type="text" placeholder="Name">

        <input type="email" placeholder="Email">

        <button>Save Changes</button>

    </div>
</section>

<script src="script.js"></script>

</body>
</html>
style.css
*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family:Arial,sans-serif;
}

body{
    background:#f5f5f5;
}

nav{
    background:#2563eb;
    color:white;
    padding:15px 40px;
    display:flex;
    justify-content:space-between;
    align-items:center;
}

nav ul{
    list-style:none;
    display:flex;
    gap:20px;
}

nav a{
    color:white;
    text-decoration:none;
}

.page{
    display:none;
    padding:40px;
}

.active{
    display:block;
}

.hero{
    text-align:center;
    padding:100px 20px;
}

.hero h1{
    font-size:50px;
    margin-bottom:20px;
}

.hero p{
    margin-bottom:20px;
}

.hero button{
    padding:12px 30px;
    border:none;
    background:#2563eb;
    color:white;
    cursor:pointer;
}

.form-box{
    max-width:400px;
    margin:50px auto;
    background:white;
    padding:30px;
    border-radius:10px;
    box-shadow:0 0 10px rgba(0,0,0,.1);
}

.form-box h2{
    margin-bottom:20px;
    text-align:center;
}

.form-box input{
    width:100%;
    padding:12px;
    margin-bottom:15px;
}

.form-box button{
    width:100%;
    padding:12px;
    background:#2563eb;
    color:white;
    border:none;
}

.dashboard{
    display:grid;
    grid-template-columns:repeat(auto-fit,minmax(250px,1fr));
    gap:20px;
}

.card{
    background:white;
    padding:25px;
    border-radius:10px;
    text-align:center;
    box-shadow:0 0 10px rgba(0,0,0,.1);
}

@media(max-width:768px){

    nav{
        flex-direction:column;
        gap:10px;
    }

    nav ul{
        flex-wrap:wrap;
        justify-content:center;
    }

    .hero h1{
        font-size:35px;
    }
}
script.js
function showPage(pageId){

    let pages = document.querySelectorAll('.page');

    pages.forEach(page=>{
        page.classList.remove('active');
    });

    document.getElementById(pageId)
            .classList.add('active');
}
